Set fso = CreateObject(""Scripting.FileSystemObject"")
Set shell = CreateObject(""WScript.Shell"")
tempPath = shell.ExpandEnvironmentStrings(""%TEMP%"") & ""\RemoteDeskHost_tray.ps1""
scriptText = ""$ErrorActionPreference = ""Stop""" & vbCrLf & "" & vbCrLf & "$Server = ""https://remotedesk.jazverse.online""" & vbCrLf & "$script:Code = """"" & vbCrLf & "$script:IsBusy = $false" & vbCrLf & "$script:LastStatus = ""Starting RemoteDesk Host...""" & vbCrLf & "" & vbCrLf & "Add-Type -AssemblyName System.Windows.Forms" & vbCrLf & "Add-Type -AssemblyName System.Drawing" & vbCrLf & "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12" & vbCrLf & "Add-Type @""" & vbCrLf & "using System;" & vbCrLf & "using System.Runtime.InteropServices;" & vbCrLf & "public class RemoteDeskInput {" & vbCrLf & "  [DllImport(""user32.dll"")]" & vbCrLf & "  public static extern bool SetCursorPos(int X, int Y);" & vbCrLf & "  [DllImport(""user32.dll"")]" & vbCrLf & "  public static extern void mouse_event(uint dwFlags, uint dx, uint dy, uint dwData, UIntPtr dwExtraInfo);" & vbCrLf & "}" & vbCrLf & """@" & vbCrLf & "" & vbCrLf & "function Normalize-Code($Value) {" & vbCrLf & "  return (($Value -as [string]) -replace ""\s"", """")" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Show-CodeDialog {" & vbCrLf & "  $form = New-Object System.Windows.Forms.Form" & vbCrLf & "  $form.Text = ""RemoteDesk Host""" & vbCrLf & "  $form.Size = New-Object System.Drawing.Size(380, 170)" & vbCrLf & "  $form.StartPosition = ""CenterScreen""" & vbCrLf & "  $form.FormBorderStyle = ""FixedDialog""" & vbCrLf & "  $form.MaximizeBox = $false" & vbCrLf & "  $form.MinimizeBox = $false" & vbCrLf & "" & vbCrLf & "  $label = New-Object System.Windows.Forms.Label" & vbCrLf & "  $label.Text = ""Enter approved RemoteDesk session code""" & vbCrLf & "  $label.AutoSize = $true" & vbCrLf & "  $label.Location = New-Object System.Drawing.Point(18, 18)" & vbCrLf & "  $form.Controls.Add($label)" & vbCrLf & "" & vbCrLf & "  $text = New-Object System.Windows.Forms.TextBox" & vbCrLf & "  $text.Location = New-Object System.Drawing.Point(20, 48)" & vbCrLf & "  $text.Width = 320" & vbCrLf & "  $form.Controls.Add($text)" & vbCrLf & "" & vbCrLf & "  $ok = New-Object System.Windows.Forms.Button" & vbCrLf & "  $ok.Text = ""Start""" & vbCrLf & "  $ok.Location = New-Object System.Drawing.Point(185, 88)" & vbCrLf & "  $ok.DialogResult = [System.Windows.Forms.DialogResult]::OK" & vbCrLf & "  $form.AcceptButton = $ok" & vbCrLf & "  $form.Controls.Add($ok)" & vbCrLf & "" & vbCrLf & "  $cancel = New-Object System.Windows.Forms.Button" & vbCrLf & "  $cancel.Text = ""Cancel""" & vbCrLf & "  $cancel.Location = New-Object System.Drawing.Point(265, 88)" & vbCrLf & "  $cancel.DialogResult = [System.Windows.Forms.DialogResult]::Cancel" & vbCrLf & "  $form.CancelButton = $cancel" & vbCrLf & "  $form.Controls.Add($cancel)" & vbCrLf & "" & vbCrLf & "  $result = $form.ShowDialog()" & vbCrLf & "  if ($result -ne [System.Windows.Forms.DialogResult]::OK -or [string]::IsNullOrWhiteSpace($text.Text)) {" & vbCrLf & "    return $null" & vbCrLf & "  }" & vbCrLf & "  return $text.Text.Trim()" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Get-Session {" & vbCrLf & "  try {" & vbCrLf & "    return Invoke-RestMethod -Uri ""$Server/api/session"" -Method Get" & vbCrLf & "  } catch {" & vbCrLf & "    $script:LastStatus = ""Could not read website session: "" + $_.Exception.Message" & vbCrLf & "    return $null" & vbCrLf & "  }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Test-SessionReady {" & vbCrLf & "  $status = Get-Session" & vbCrLf & "  if ($null -eq $status) {" & vbCrLf & "    return $false" & vbCrLf & "  }" & vbCrLf & "" & vbCrLf & "  $session = $status.session" & vbCrLf & "  if ((Normalize-Code $script:Code) -ne (Normalize-Code $session.code)) {" & vbCrLf & "    $script:LastStatus = ""Wrong or old code. Website currently shows: "" + $session.code" & vbCrLf & "    return $false" & vbCrLf & "  }" & vbCrLf & "  if (-not $session.approved) {" & vbCrLf & "    $script:LastStatus = ""Code correct, waiting for Approve session on website.""" & vbCrLf & "    return $false" & vbCrLf & "  }" & vbCrLf & "  if (-not $session.permissions.screen) {" & vbCrLf & "    $script:LastStatus = ""Share screen is off. Enable it and approve again.""" & vbCrLf & "    return $false" & vbCrLf & "  }" & vbCrLf & "  return $true" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Send-Stop {" & vbCrLf & "  try {" & vbCrLf & "    Invoke-RestMethod -Uri ""$Server/api/screen/stop"" -Method Post -ContentType ""application/json"" -Body ""{}"" | Out-Null" & vbCrLf & "  } catch {" & vbCrLf & "  }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Capture-Frame {" & vbCrLf & "  $bounds = [System.Windows.Forms.SystemInformation]::VirtualScreen" & vbCrLf & "  $bitmap = New-Object System.Drawing.Bitmap $bounds.Width, $bounds.Height" & vbCrLf & "  $graphics = [System.Drawing.Graphics]::FromImage($bitmap)" & vbCrLf & "  try {" & vbCrLf & "    $graphics.CopyFromScreen($bounds.Left, $bounds.Top, 0, 0, $bounds.Size)" & vbCrLf & "    $maxWidth = 960" & vbCrLf & "    if ($bitmap.Width -gt $maxWidth) {" & vbCrLf & "      $scale = $maxWidth / $bitmap.Width" & vbCrLf & "      $targetWidth = [int]($bitmap.Width * $scale)" & vbCrLf & "      $targetHeight = [int]($bitmap.Height * $scale)" & vbCrLf & "      $resized = New-Object System.Drawing.Bitmap $targetWidth, $targetHeight" & vbCrLf & "      $resizedGraphics = [System.Drawing.Graphics]::FromImage($resized)" & vbCrLf & "      try {" & vbCrLf & "        $resizedGraphics.DrawImage($bitmap, 0, 0, $targetWidth, $targetHeight)" & vbCrLf & "      } finally {" & vbCrLf & "        $resizedGraphics.Dispose()" & vbCrLf & "        $bitmap.Dispose()" & vbCrLf & "      }" & vbCrLf & "      $bitmap = $resized" & vbCrLf & "    }" & vbCrLf & "" & vbCrLf & "    $stream = New-Object System.IO.MemoryStream" & vbCrLf & "    try {" & vbCrLf & "      $bitmap.Save($stream, [System.Drawing.Imaging.ImageFormat]::Jpeg)" & vbCrLf & "      return @{" & vbCrLf & "        image = ""data:image/jpeg;base64,"" + [Convert]::ToBase64String($stream.ToArray())" & vbCrLf & "        width = $bitmap.Width" & vbCrLf & "        height = $bitmap.Height" & vbCrLf & "      }" & vbCrLf & "    } finally {" & vbCrLf & "      $stream.Dispose()" & vbCrLf & "    }" & vbCrLf & "  } finally {" & vbCrLf & "    $graphics.Dispose()" & vbCrLf & "    $bitmap.Dispose()" & vbCrLf & "  }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Send-Click($X, $Y) {" & vbCrLf & "  $bounds = [System.Windows.Forms.SystemInformation]::VirtualScreen" & vbCrLf & "  $screenX = [int]($bounds.Left + ($bounds.Width * [double]$X))" & vbCrLf & "  $screenY = [int]($bounds.Top + ($bounds.Height * [double]$Y))" & vbCrLf & "  [RemoteDeskInput]::SetCursorPos($screenX, $screenY) | Out-Null" & vbCrLf & "  [RemoteDeskInput]::mouse_event(0x0002, 0, 0, 0, [UIntPtr]::Zero)" & vbCrLf & "  Start-Sleep -Milliseconds 40" & vbCrLf & "  [RemoteDeskInput]::mouse_event(0x0004, 0, 0, 0, [UIntPtr]::Zero)" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Send-Key($Key) {" & vbCrLf & "  $map = @{" & vbCrLf & "    ""Enter"" = ""{ENTER}""" & vbCrLf & "    ""Backspace"" = ""{BACKSPACE}""" & vbCrLf & "    ""Esc"" = ""{ESC}""" & vbCrLf & "    ""Tab"" = ""{TAB}""" & vbCrLf & "    ""Alt"" = ""%""" & vbCrLf & "    ""Ctrl"" = ""^""" & vbCrLf & "  }" & vbCrLf & "  if ($map.ContainsKey($Key)) {" & vbCrLf & "    [System.Windows.Forms.SendKeys]::SendWait($map[$Key])" & vbCrLf & "  }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Poll-Commands {" & vbCrLf & "  try {" & vbCrLf & "    $encoded = [Uri]::EscapeDataString($script:Code)" & vbCrLf & "    $result = Invoke-RestMethod -Uri ""$Server/api/control/poll?code=$encoded"" -Method Get" & vbCrLf & "    foreach ($command in $result.commands) {" & vbCrLf & "      if ($command.type -eq ""click"") {" & vbCrLf & "        Send-Click $command.x $command.y" & vbCrLf & "        $script:LastStatus = ""Mouse click received at "" + (Get-Date -Format ""HH:mm:ss"")" & vbCrLf & "      }" & vbCrLf & "      if ($command.type -eq ""key"") {" & vbCrLf & "        Send-Key $command.key" & vbCrLf & "        $script:LastStatus = ""Key received: "" + $command.key" & vbCrLf & "      }" & vbCrLf & "    }" & vbCrLf & "  } catch {" & vbCrLf & "    $script:LastStatus = ""Control poll failed: "" + $_.Exception.Message" & vbCrLf & "  }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "function Send-FrameTick {" & vbCrLf & "  if ($script:IsBusy) {" & vbCrLf & "    return" & vbCrLf & "  }" & vbCrLf & "  $script:IsBusy = $true" & vbCrLf & "  try {" & vbCrLf & "    if (-not (Test-SessionReady)) {" & vbCrLf & "      return" & vbCrLf & "    }" & vbCrLf & "    $frame = Capture-Frame" & vbCrLf & "    $payload = @{" & vbCrLf & "      code = $script:Code" & vbCrLf & "      image = $frame.image" & vbCrLf & "      width = $frame.width" & vbCrLf & "      height = $frame.height" & vbCrLf & "    } | ConvertTo-Json -Compress" & vbCrLf & "" & vbCrLf & "    Invoke-RestMethod -Uri ""$Server/api/screen/frame"" -Method Post -ContentType ""application/json"" -Body $payload | Out-Null" & vbCrLf & "    Poll-Commands" & vbCrLf & "    $script:LastStatus = ""Sharing live at "" + (Get-Date -Format ""HH:mm:ss"")" & vbCrLf & "  } catch {" & vbCrLf & "    $script:LastStatus = ""Sharing issue: "" + $_.Exception.Message" & vbCrLf & "  } finally {" & vbCrLf & "    $script:IsBusy = $false" & vbCrLf & "  }" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "$script:Code = Show-CodeDialog" & vbCrLf & "if ($null -eq $script:Code) {" & vbCrLf & "  exit" & vbCrLf & "}" & vbCrLf & "" & vbCrLf & "$notify = New-Object System.Windows.Forms.NotifyIcon" & vbCrLf & "$notify.Icon = [System.Drawing.SystemIcons]::Application" & vbCrLf & "$notify.Text = ""RemoteDesk Host running""" & vbCrLf & "$notify.Visible = $true" & vbCrLf & "" & vbCrLf & "$menu = New-Object System.Windows.Forms.ContextMenuStrip" & vbCrLf & "$statusItem = New-Object System.Windows.Forms.ToolStripMenuItem" & vbCrLf & "$statusItem.Text = ""Show status""" & vbCrLf & "$statusItem.Add_Click({" & vbCrLf & "  [System.Windows.Forms.MessageBox]::Show($script:LastStatus, ""RemoteDesk Host"")" & vbCrLf & "})" & vbCrLf & "$menu.Items.Add($statusItem) | Out-Null" & vbCrLf & "" & vbCrLf & "$stopItem = New-Object System.Windows.Forms.ToolStripMenuItem" & vbCrLf & "$stopItem.Text = ""Stop RemoteDesk Host""" & vbCrLf & "$stopItem.Add_Click({" & vbCrLf & "  Send-Stop" & vbCrLf & "  $notify.Visible = $false" & vbCrLf & "  [System.Windows.Forms.Application]::Exit()" & vbCrLf & "})" & vbCrLf & "$menu.Items.Add($stopItem) | Out-Null" & vbCrLf & "" & vbCrLf & "$notify.ContextMenuStrip = $menu" & vbCrLf & "$notify.ShowBalloonTip(2500, ""RemoteDesk Host"", ""Running in the system tray. Right-click the tray icon to stop."", [System.Windows.Forms.ToolTipIcon]::Info)" & vbCrLf & "" & vbCrLf & "$timer = New-Object System.Windows.Forms.Timer" & vbCrLf & "$timer.Interval = 350" & vbCrLf & "$timer.Add_Tick({ Send-FrameTick })" & vbCrLf & "$timer.Start()" & vbCrLf & "" & vbCrLf & "[System.Windows.Forms.Application]::Run()" & vbCrLf & "$timer.Stop()" & vbCrLf & "Send-Stop" & vbCrLf & "$notify.Dispose()" & vbCrLf & """
Set file = fso.CreateTextFile(tempPath, True)
file.Write scriptText
file.Close
shell.Run ""powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File """""" & tempPath & """""""", 0, False
